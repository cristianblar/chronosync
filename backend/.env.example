APP_NAME="ChronoSync API"
DEBUG=false
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chronosync
REDIS_URL=redis://localhost:6379
JWT_SECRET_KEY=change-me
RESET_TOKEN_EXPIRE_MINUTES=60
VERIFY_TOKEN_EXPIRE_MINUTES=1440
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
# SendGrid (production). Leave empty to use local SMTP (Mailhog).
SENDGRID_API_KEY=
FROM_EMAIL=noreply@chronosync.local
# Local SMTP settings (Mailhog for development)
SMTP_HOST=mailhog
SMTP_PORT=1025
SENTRY_DSN=
